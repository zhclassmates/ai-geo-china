{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.7.3",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",

  "permissions": [
    "sidePanel",
    "storage",
    "contextMenus",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "clipboardRead",
    "downloads"
  ],

  "host_permissions": [
    "*://www.doubao.com/*",
    "*://api.github.com/*"
  ],

  "optional_host_permissions": [
    "*://localhost/*",
    "*://127.0.0.1/*",
    "*://*/*"
  ],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },

  "options_page": "options/options.html",

  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "__MSG_actionDefaultTitle__"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "__MSG_commandOpenSidebar__"
    },
    "open-prompt-library": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "__MSG_commandOpenPromptLibrary__"
    },
    "toggle-focus": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "__MSG_commandToggleFocus__"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },


  "content_scripts": [
    {
      "matches": [
        "https://www.doubao.com/*"
      ],
      "js": [
        "content-scripts/button-finder-utils.js",
        "content-scripts/enter-behavior-utils.js",
        "content-scripts/text-injection-all-providers.js",
        "content-scripts/conversation-extractor-utils.js",
        "content-scripts/language-detector.js",
        "content-scripts/china-history-extractor.js",
        "content-scripts/focus-toggle.js"
      ],
      "css": ["content-scripts/china-save-button.css"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": [
        "libs/Readability.js",
        "content-scripts/page-content-extractor.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "bypass_headers",
        "enabled": true,
        "path": "rules/bypass-headers.json"
      }
    ]
  },

  "web_accessible_resources": [
    {
      "resources": [
        "data/prompt-libraries/default-prompts.json",
        "data/version-info.json",
        "_locales/en/messages.json",
        "_locales/zh_CN/messages.json",
        "_locales/zh_TW/messages.json"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
